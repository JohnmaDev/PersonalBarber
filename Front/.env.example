# Configuración del frontend para BarberCol
# Copia este archivo como .env.local y completa los valores

# Webhook de Make.com para procesar las reservas
VUE_APP_MAKE_WEBHOOK=tu_url_de_make_aqui

# URL de la API de Google Apps Script (implementación como Web App)
VUE_APP_SLOTS_API=tu_url_de_script_google_aqui

# PIN de acceso para el Panel de Administración (ej: 111111) debe coincidir con el GAS
VUE_APP_ADMIN_PIN=tu_pin_secreto_aqui
